<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hello World - Advanced Example</title>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&family=Pacifico&display=swap" rel="stylesheet">
<!-- CSS Styles -->
<style>
/* Reset some default styles */
* {
margin: 0;
padding: 0;
box-sizing: border-box;
}
html, body {
height: 100%;
font-family: 'Roboto', sans-serif;
background: linear-gradient(135deg, #89f7fe, #66a6ff);
display: flex;
justify-content: center;
align-items: center;
overflow: hidden;
}
/* Container */
.container {
text-align: center;
background: rgba(255, 255, 255, 0.85);
padding: 50px 80px;
border-radius: 20px;
box-shadow: 0 10px 30px rgba(0,0,0,0.2);
position: relative;
z-index: 1;
}
h1 {
font-family: 'Pacifico', cursive;
font-size: 4rem;
color: #333;
margin-bottom: 20px;
animation: fadeIn 2s ease-in-out forwards;
}
p {
font-size: 1.2rem;
color: #555;
margin-bottom: 40px;
opacity: 0;
animation: fadeIn 2s 1s forwards;
}
/* Button */
.btn {
padding: 15px 30px;
font-size: 1rem;
color: #fff;
background: #66a6ff;
border: none;
border-radius: 50px;
cursor: pointer;
transition: all 0.3s ease;
}
.btn:hover {
background: #89f7fe;
transform: scale(1.1);
}
/* Floating circles background animation */
.circle {
position: absolute;
